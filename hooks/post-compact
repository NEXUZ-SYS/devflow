#!/usr/bin/env bash
# DevFlow PostCompact hook
# Injects enriched checkpoint directly into LLM context
# Self-sufficient: does NOT depend on external APIs

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
PLUGIN_ROOT="$(cd "${SCRIPT_DIR}/.." && pwd)"
CHECKPOINT=".context/workflow/.checkpoint/last.json"

# --- Load i18n ---

source "${SCRIPT_DIR}/i18n.sh"
load_i18n

# --- Escape for JSON ---

escape_for_json() {
    local s="$1"
    s="${s//\\/\\\\}"
    s="${s//\"/\\\"}"
    s="${s//$'\n'/\\n}"
    s="${s//$'\r'/\\r}"
    s="${s//$'\t'/\\t}"
    printf '%s' "$s"
}

# --- Build rehydration context ---

rehydration="$MSG_REHYDRATION_HEADER"

if [ -f "$CHECKPOINT" ]; then
  checkpoint_content=$(cat "$CHECKPOINT" 2>/dev/null || echo "{}")

  # Extract handoff directly (most valuable for resumption)
  handoff=$(python3 -c "
import json, sys
try:
    d = json.load(open('$CHECKPOINT'))
    h = d.get('handoff', '')
    if h: print(h)
except: pass
" 2>/dev/null || echo "")

  # Extract git info
  git_info=$(python3 -c "
import json, sys
try:
    d = json.load(open('$CHECKPOINT'))
    g = d.get('git', {})
    print(f\"Branch: {g.get('branch','?')} | Commit: {g.get('last_commit','?')}\")
    dirty = g.get('dirty_files', [])
    if dirty:
        print(f\"Dirty files: {', '.join(dirty[:10])}\")
except: pass
" 2>/dev/null || echo "")

  # Extract plan summary
  plan=$(python3 -c "
import json, sys
try:
    d = json.load(open('$CHECKPOINT'))
    p = d.get('active_plan', '')
    if p: print(p[:3000])
except: pass
" 2>/dev/null || echo "")

  # Build context with available data
  if [ -n "$git_info" ]; then
    rehydration="$rehydration

--- Git State ---
$git_info"
  fi

  if [ -n "$handoff" ]; then
    rehydration="$rehydration

$MSG_REHYDRATION_HANDOFF_HEADER
$handoff"
  fi

  if [ -n "$plan" ]; then
    rehydration="$rehydration

$MSG_REHYDRATION_PLAN_HEADER
$plan"
  fi

  # Fallback instructions only if no handoff was captured
  if [ -z "$handoff" ] && [ -z "$plan" ]; then
    rehydration="$rehydration

$MSG_REHYDRATION_FALLBACK_HEADER
$MSG_REHYDRATION_FALLBACK"
  fi

else
  rehydration="$rehydration

$MSG_REHYDRATION_NO_CHECKPOINT"
fi

rehydration="$rehydration

--- $(echo "$MSG_REHYDRATION_INSTRUCTION" | head -1) ---
$MSG_REHYDRATION_INSTRUCTION"

# --- Append language context ---

lang_context=$(build_language_context)
rehydration="$rehydration

--- Language ---
$lang_context"

# --- Output ---

rehydration_escaped=$(escape_for_json "$rehydration")

if [ -n "${CLAUDE_PLUGIN_ROOT:-}" ]; then
  printf '{\n  "hookSpecificOutput": {\n    "hookEventName": "PostCompact",\n    "additionalContext": "%s"\n  }\n}\n' "$rehydration_escaped"
else
  printf '{\n  "additional_context": "%s"\n}\n' "$rehydration_escaped"
fi

exit 0
