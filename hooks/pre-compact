#!/usr/bin/env bash
# DevFlow PreCompact hook
# Saves enriched snapshot before context compaction
# Captures: git state, handoff.md, active plan

set -euo pipefail

CHECKPOINT_DIR=".context/workflow/.checkpoint"
mkdir -p "$CHECKPOINT_DIR" 2>/dev/null || true

# --- Git state ---

TIMESTAMP=$(date -u +%Y-%m-%dT%H:%M:%SZ 2>/dev/null || echo "unknown")
BRANCH=$(git rev-parse --abbrev-ref HEAD 2>/dev/null || echo "unknown")
LAST_COMMIT=$(git log --format='%h %s' -1 2>/dev/null || echo "none")

# Dirty files (modified + untracked, limit to 20)
DIRTY_FILES="[]"
if command -v git >/dev/null 2>&1; then
  dirty=$(git status --porcelain 2>/dev/null | head -20 | while IFS= read -r line; do
    [ -n "$line" ] && printf '"%s",' "$line"
  done)
  dirty="${dirty%,}"
  [ -n "$dirty" ] && DIRTY_FILES="[$dirty]"
fi

# --- Handoff content (from continuous handoff, layer 3) ---

HANDOFF_CONTENT=""
HANDOFF_FILE="$CHECKPOINT_DIR/handoff.md"
if [ -f "$HANDOFF_FILE" ]; then
  HANDOFF_CONTENT=$(cat "$HANDOFF_FILE" 2>/dev/null || echo "")
fi

# Auto-generate handoff from git state if handoff.md is empty
if [ -z "$HANDOFF_CONTENT" ]; then
  # Detect main branch name
  MAIN_BRANCH=$(git symbolic-ref refs/remotes/origin/HEAD 2>/dev/null | sed 's|refs/remotes/origin/||' || echo "main")

  # Recent commits on current branch (since diverging from main)
  RECENT_COMMITS=""
  if [ "$BRANCH" != "$MAIN_BRANCH" ] && [ "$BRANCH" != "master" ]; then
    RECENT_COMMITS=$(git log "${MAIN_BRANCH}..HEAD" --format='- %h %s' -10 2>/dev/null || echo "")
  fi
  # Fallback: last 5 commits if no branch-specific commits
  if [ -z "$RECENT_COMMITS" ]; then
    RECENT_COMMITS=$(git log --format='- %h %s' -5 2>/dev/null || echo "")
  fi

  # Read workflow status if available
  WORKFLOW_SUMMARY=""
  if [ -f ".context/workflow/status.yaml" ]; then
    WORKFLOW_SUMMARY=$(head -20 ".context/workflow/status.yaml" 2>/dev/null || echo "")
  fi

  if [ -n "$RECENT_COMMITS" ] || [ -n "$WORKFLOW_SUMMARY" ]; then
    AUTO_HANDOFF="## Auto-generated Handoff (handoff.md was empty)"
    if [ -n "$WORKFLOW_SUMMARY" ]; then
      AUTO_HANDOFF="${AUTO_HANDOFF}
### Workflow Status
\`\`\`yaml
${WORKFLOW_SUMMARY}
\`\`\`"
    fi
    if [ -n "$RECENT_COMMITS" ]; then
      AUTO_HANDOFF="${AUTO_HANDOFF}
### Recent Commits (this branch)
${RECENT_COMMITS}"
    fi
    HANDOFF_CONTENT="$AUTO_HANDOFF"
  fi
fi

# --- Active plan (smart detection: status.yaml → branch match → newest .md) ---

ACTIVE_PLAN=""

# Strategy 1: Read plan reference from workflow status.yaml
if [ -f ".context/workflow/status.yaml" ]; then
  PLAN_FILE=$(python3 - ".context/workflow/status.yaml" << 'PYEOF'
import sys
file_path = sys.argv[1]
try:
    import yaml
    with open(file_path) as f:
        data = yaml.safe_load(f) or {}
    plan = data.get('plan', data.get('planFile', ''))
    if plan:
        print(plan)
except ImportError:
    import re
    for line in open(file_path):
        m = re.match(r'\s*plan(?:File)?:\s*(.+)', line.strip())
        if m:
            val = m.group(1).strip().strip('"').strip("'")
            print(val)
            break
except Exception:
    pass
PYEOF
  )
  if [ -n "$PLAN_FILE" ] && [ -f "$PLAN_FILE" ]; then
    ACTIVE_PLAN=$(head -200 "$PLAN_FILE" 2>/dev/null || echo "")
  fi
fi

# Strategy 2: Match plan file by branch name (feature/foo-bar → *foo-bar*.md)
if [ -z "$ACTIVE_PLAN" ] && [ "$BRANCH" != "main" ] && [ "$BRANCH" != "master" ]; then
  FEATURE_NAME="${BRANCH#*/}"
  for dir in ".context/plans" "docs/superpowers/plans"; do
    if [ -d "$dir" ]; then
      matched_plan=$(ls -t "$dir"/*"$FEATURE_NAME"*.md 2>/dev/null | head -1 || true)
      if [ -n "$matched_plan" ]; then
        ACTIVE_PLAN=$(head -200 "$matched_plan" 2>/dev/null || echo "")
        break
      fi
    fi
  done
fi

# Strategy 3: Fallback to newest .md in plans directories
if [ -z "$ACTIVE_PLAN" ]; then
  PLANS_DIR=".context/plans"
  if [ -d "$PLANS_DIR" ]; then
    newest_plan=$(ls -t "$PLANS_DIR"/*.md 2>/dev/null | head -1)
    if [ -n "$newest_plan" ]; then
      ACTIVE_PLAN=$(head -200 "$newest_plan" 2>/dev/null || echo "")
    fi
  fi
fi

SP_PLANS_DIR="docs/superpowers/plans"
if [ -z "$ACTIVE_PLAN" ] && [ -d "$SP_PLANS_DIR" ]; then
  newest_plan=$(ls -t "$SP_PLANS_DIR"/*.md 2>/dev/null | head -1)
  if [ -n "$newest_plan" ]; then
    ACTIVE_PLAN=$(head -200 "$newest_plan" 2>/dev/null || echo "")
  fi
fi

# --- Napkin curation trigger ---

NAPKIN_INSTRUCTION=""
if [ -f ".context/napkin.md" ]; then
  NAPKIN_INSTRUCTION="Before compacting, curate .context/napkin.md: merge duplicates, remove stale items, enforce max 15 per category / 7 per agent section, re-prioritize by importance."
fi

# --- MemPalace diary flush ---

MEMPALACE_INSTRUCTION=""
mempalace_available="false"
if [ -f ".mcp.json" ] && grep -q "mempalace" ".mcp.json" 2>/dev/null; then
  mempalace_available="true"
elif [ -f "${HOME}/.config/claude/mcp.json" ] && grep -q "mempalace" "${HOME}/.config/claude/mcp.json" 2>/dev/null; then
  mempalace_available="true"
fi

if [ "$mempalace_available" = "true" ]; then
  mp_auto_diary="true"
  if [ -f ".context/.devflow.yaml" ]; then
    mp_auto_diary=$(python3 - ".context/.devflow.yaml" << 'PYEOF'
import sys
try:
    import yaml
    with open(sys.argv[1]) as f:
        data = yaml.safe_load(f) or {}
    print(str(data.get('mempalace', {}).get('auto_diary', True)).lower())
except:
    print('true')
PYEOF
    )
  fi
  if [ "$mp_auto_diary" = "true" ]; then
    MEMPALACE_INSTRUCTION="Before compacting, save a diary entry to MemPalace summarizing: which agents worked this session, key decisions made, artifacts produced, and current workflow state. Use the project wing and current PREVC phase as room."
  fi
fi

# --- Escape for JSON ---

escape_for_json() {
    local s="$1"
    s="${s//\\/\\\\}"
    s="${s//\"/\\\"}"
    s="${s//$'\n'/\\n}"
    s="${s//$'\r'/\\r}"
    s="${s//$'\t'/\\t}"
    printf '%s' "$s"
}

handoff_escaped=$(escape_for_json "$HANDOFF_CONTENT")
plan_escaped=$(escape_for_json "$ACTIVE_PLAN")
napkin_instruction_escaped=$(escape_for_json "$NAPKIN_INSTRUCTION")
mempalace_instruction_escaped=$(escape_for_json "$MEMPALACE_INSTRUCTION")

# --- Write enriched checkpoint ---

cat > "$CHECKPOINT_DIR/last.json" << EOF
{
  "timestamp": "$TIMESTAMP",
  "git": {
    "branch": "$BRANCH",
    "last_commit": "$LAST_COMMIT",
    "dirty_files": $DIRTY_FILES
  },
  "handoff": "$handoff_escaped",
  "active_plan": "$plan_escaped",
  "napkin_instruction": "$napkin_instruction_escaped",
  "mempalace_instruction": "$mempalace_instruction_escaped"
}
EOF

exit 0
