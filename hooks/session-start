#!/usr/bin/env bash
# DevFlow SessionStart hook
# Detects available systems and injects unified context

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
PLUGIN_ROOT="$(cd "${SCRIPT_DIR}/.." && pwd)"

# --- Load i18n ---

source "${SCRIPT_DIR}/i18n.sh"
load_i18n

# --- Mode Detection ---

mode="minimal"
superpowers_available="false"
dotcontext_mcp="false"
dotcontext_cli="false"
dotcontext_lite="false"

# Check superpowers: look in installed_plugins.json (Claude Code plugin system)
installed_plugins="${HOME}/.claude/plugins/installed_plugins.json"
if [ -f "$installed_plugins" ] && grep -q '"superpowers@' "$installed_plugins" 2>/dev/null; then
  superpowers_available="true"
fi

# Fallback: check if superpowers skills directory exists in plugin cache
if [ "$superpowers_available" = "false" ]; then
  for dir in "${HOME}/.claude/plugins/cache"/*/superpowers/*/skills; do
    if [ -d "$dir" ]; then
      superpowers_available="true"
      break
    fi
  done
fi

# Check dotcontext MCP: look for .mcp.json or mcp config referencing dotcontext
project_root="${PWD}"
if [ -f "${project_root}/.mcp.json" ] && grep -q "dotcontext" "${project_root}/.mcp.json" 2>/dev/null; then
  dotcontext_mcp="true"
  mode="full"
elif [ -f "${HOME}/.config/claude/mcp.json" ] && grep -q "dotcontext" "${HOME}/.config/claude/mcp.json" 2>/dev/null; then
  dotcontext_mcp="true"
  mode="full"
elif [ -f "${project_root}/.omp/mcp.json" ] && grep -q '"dotcontext"' "${project_root}/.omp/mcp.json" 2>/dev/null; then
  dotcontext_mcp="true"
  mode="full"
elif [ -f "${HOME}/.omp/agent/mcp.json" ] && grep -q '"dotcontext"' "${HOME}/.omp/agent/mcp.json" 2>/dev/null; then
  dotcontext_mcp="true"
  mode="full"
fi

# Check mempalace MCP: look for mempalace in .mcp.json or global mcp config
mempalace_available="false"
if [ -f "${project_root}/.mcp.json" ] && grep -q "mempalace" "${project_root}/.mcp.json" 2>/dev/null; then
  mempalace_available="true"
elif [ -f "${HOME}/.config/claude/mcp.json" ] && grep -q "mempalace" "${HOME}/.config/claude/mcp.json" 2>/dev/null; then
  mempalace_available="true"
elif [ -f "${project_root}/.omp/mcp.json" ] && grep -q '"mempalace"' "${project_root}/.omp/mcp.json" 2>/dev/null; then
  mempalace_available="true"
elif [ -f "${HOME}/.omp/agent/mcp.json" ] && grep -q '"mempalace"' "${HOME}/.omp/agent/mcp.json" 2>/dev/null; then
  mempalace_available="true"
fi

# Check docs-mcp-server MCP: searched indices for stack docs via MCP tools
# (replaces the legacy .context/stacks/refs/<lib>@<ver>.md paradigm)
docs_mcp_available="false"
if [ -f "${project_root}/.mcp.json" ] && grep -q "docs-mcp-server" "${project_root}/.mcp.json" 2>/dev/null; then
  docs_mcp_available="true"
elif [ -f "${HOME}/.config/claude/mcp.json" ] && grep -q "docs-mcp-server" "${HOME}/.config/claude/mcp.json" 2>/dev/null; then
  docs_mcp_available="true"
fi

# Check dotcontext CLI: global install or npx available
if [ "$mode" != "full" ]; then
  if command -v dotcontext >/dev/null 2>&1; then
    dotcontext_cli="true"
  elif command -v npx >/dev/null 2>&1 && npx --yes @dotcontext/cli --version >/dev/null 2>&1; then
    dotcontext_cli="true"
  fi
fi

# Check dotcontext lite: .context/ directory exists
if [ "$mode" != "full" ] && [ -d "${project_root}/.context" ]; then
  dotcontext_lite="true"
  mode="lite"
fi

# --- Detect active autonomous workflow ---

autonomous_context=""
stories_file="${project_root}/.context/workflow/stories.yaml"
if [ -f "$stories_file" ]; then
  # Extract key stats from stories.yaml using grep (no yaml parser needed)
  # Sanitize: strip anything outside safe chars to prevent prompt injection
  sanitize_str() { printf '%s' "$1" | tr -cd 'a-zA-Z0-9 _./:-'; }
  sanitize_int() { printf '%s' "$1" | tr -cd '0-9'; }

  autonomy_mode=$(sanitize_str "$(grep '^autonomy:' "$stories_file" 2>/dev/null | head -1 | sed 's/autonomy: *//' | tr -d '"' || echo "")")
  current_autonomy=$(sanitize_str "$(grep 'current_autonomy:' "$stories_file" 2>/dev/null | head -1 | sed 's/.*current_autonomy: *//' | tr -d '"' || echo "")")
  total=$(sanitize_int "$(grep 'total:' "$stories_file" 2>/dev/null | head -1 | sed 's/.*total: *//' || echo "0")")
  completed=$(sanitize_int "$(grep 'completed:' "$stories_file" 2>/dev/null | head -1 | sed 's/.*completed: *//' || echo "0")")
  escalated=$(sanitize_int "$(grep 'escalated:' "$stories_file" 2>/dev/null | head -2 | tail -1 | sed 's/.*escalated: *//' || echo "0")")
  feature=$(sanitize_str "$(grep '^feature:' "$stories_file" 2>/dev/null | head -1 | sed 's/feature: *//' | tr -d '"' || echo "")")

  # Guard: skip injection if key fields are empty (malformed YAML)
  if [ -n "$autonomy_mode" ] && [ "$autonomy_mode" != "supervised" ] && [ -n "$total" ] && [ "$total" != "0" ]; then
    active_mode="${current_autonomy:-$autonomy_mode}"
    autonomous_context="\\n**AUTONOMOUS WORKFLOW ACTIVE**\\n"
    autonomous_context+="- Feature: ${feature}\\n"
    autonomous_context+="- Mode: ${active_mode}\\n"
    autonomous_context+="- Progress: ${completed}/${total} stories (${escalated} escalated)\\n"
    autonomous_context+="- To resume: say \\\"continue\\\" or invoke devflow:autonomous-loop\\n"
  fi
fi

# --- Read using-devflow skill ---

using_devflow_content=$(cat "${PLUGIN_ROOT}/skills/using-devflow/SKILL.md" 2>&1 || echo "Error reading using-devflow skill")

# --- Escape for JSON ---

escape_for_json() {
    local s="$1"
    s="${s//\\/\\\\}"
    s="${s//\"/\\\"}"
    s="${s//$'\n'/\\n}"
    s="${s//$'\r'/\\r}"
    s="${s//$'\t'/\\t}"
    printf '%s' "$s"
}

# --- Detect and inject napkin runbook ---

napkin_context=""
napkin_file="${project_root}/.context/napkin.md"

if [ -f "$napkin_file" ]; then
  napkin_content=$(cat "$napkin_file" 2>/dev/null || echo "")
  if [ -n "$napkin_content" ]; then
    napkin_escaped=$(escape_for_json "$napkin_content")
    napkin_context="\\n<NAPKIN_RUNBOOK>\\n${napkin_escaped}\\n</NAPKIN_RUNBOOK>\\n"
  fi
elif [ -d "${project_root}/.context" ]; then
  cat > "$napkin_file" << 'NAPKIN_TMPL'
# Napkin Runbook

## Curation Rules
- Re-prioritize on every read.
- Keep recurring, high-value notes only.
- Max 15 items per category, max 7 per agent section.
- Each item includes date + "Do instead".

## Execution & Validation
(empty)

## Shell & Command Reliability
(empty)

## Domain Behavior Guardrails
(empty)

## User Directives
(empty)

## Agent-Specific Notes
<!-- Sections appear on demand: ### agent-name -->
NAPKIN_TMPL
  napkin_content=$(cat "$napkin_file")
  napkin_escaped=$(escape_for_json "$napkin_content")
  napkin_context="\\n<NAPKIN_RUNBOOK>\\n${napkin_escaped}\\n</NAPKIN_RUNBOOK>\\n"
fi

# --- Detect and inject ADR guardrails (Semana 0 dual-read) ---
#
# Canonical path: .context/adrs/ (v1.0+)
# Legacy path:    .context/docs/adrs/ (deprecated, removed in v1.2)
# Both are scanned during transition. If only legacy contributes ADRs, emit
# LEGACY_PATH_DETECTED warning to stderr (per N6).

adr_context=""
adr_dir_new="${project_root}/.context/adrs"
adr_dir_legacy="${project_root}/.context/docs/adrs"

# Build list of existing ADR directories (canonical first)
adr_dirs=()
[ -d "$adr_dir_new" ] && adr_dirs+=("$adr_dir_new")
[ -d "$adr_dir_legacy" ] && adr_dirs+=("$adr_dir_legacy")

if [ "${#adr_dirs[@]}" -gt 0 ]; then
  adr_count=0
  legacy_contributed=0
  adr_guardrails_content=""

  # Track seen filenames so canonical wins on conflict (legacy is shadowed)
  declare -A seen_files

  for d in "${adr_dirs[@]}"; do
    while IFS= read -r adr_file; do
      [ -f "$adr_file" ] || continue
      fn=$(basename "$adr_file")
      [ -n "${seen_files[$fn]:-}" ] && continue
      seen_files[$fn]=1

      adr_status=$(grep -m1 '^status:' "$adr_file" 2>/dev/null | sed 's/^status:[[:space:]]*//' | tr -d '"' | tr -d "'")
      [ "$adr_status" = "Aprovado" ] || continue

      adr_name=$(grep -m1 '^name:' "$adr_file" 2>/dev/null | sed 's/^name:[[:space:]]*//' | tr -d '"' | tr -d "'")
      adr_stack=$(grep -m1 '^stack:' "$adr_file" 2>/dev/null | sed 's/^stack:[[:space:]]*//' | tr -d '"' | tr -d "'")

      guardrails=$(awk '/^## Guardrails[[:space:]]*$/{flag=1; next} /^## /{flag=0} flag' "$adr_file")

      if [ -n "$guardrails" ]; then
        adr_count=$((adr_count + 1))
        if [ "$d" = "$adr_dir_legacy" ]; then
          legacy_contributed=1
        fi
        adr_guardrails_content+=$'\n### '"${adr_name}"' (stack: '"${adr_stack}"')'$'\n'"${guardrails}"$'\n'
      fi
    done < <(find "$d" -maxdepth 1 -type f -name '*.md' ! -name 'README.md' 2>/dev/null | sort)
  done

  # N6: emit warning when legacy path contributed AND canonical doesn't exist
  if [ "$legacy_contributed" = "1" ] && [ ! -d "$adr_dir_new" ]; then
    echo "[devflow] WARN: ADRs loaded from legacy path .context/docs/adrs/ — migrate to .context/adrs/ before v1.2 (see ADR-001)." >&2
  fi

  if [ "$adr_count" -gt 0 ]; then
    adr_header="Loaded ${adr_count} active ADR(s). These are HARD CONSTRAINTS — apply during brainstorming, design, and implementation. Do not propose alternatives already rejected in ADRs."
    adr_escaped=$(escape_for_json "${adr_header}${adr_guardrails_content}")
    adr_context="\\n<ADR_GUARDRAILS>\\n${adr_escaped}\\n</ADR_GUARDRAILS>\\n"
  fi
fi

# --- DevFlow context index (Camada 1: standards + stack refs available) ---
# Lists declared standards and scraped/pending stack refs so the LLM knows
# what's available without reading every file. Pure scan — no network/LLM.
# Also clears the per-session nudge cache so Camada 2 fires fresh in this
# new conversation (cache is time-TTL'd at 6h, but sessions can overlap).

context_index_context=""
# R2 gate: fire when project has standards/stacks OR when the plugin ships
# default standards (CLAUDE_PLUGIN_ROOT set and assets/standards/ exists).
# SI-1: plugin path passed as a CLI argument, never interpolated into node -e.
_plugin_has_defaults="false"
if [ -n "${PLUGIN_ROOT:-}" ] && [ -d "${PLUGIN_ROOT}/assets/standards" ]; then
  _plugin_has_defaults="true"
fi
if [ -d "${project_root}/.context/standards" ] || [ -f "${project_root}/.context/stacks/manifest.yaml" ] || [ "$_plugin_has_defaults" = "true" ]; then
  (cd "${project_root}" && node "${PLUGIN_ROOT}/scripts/lib/edit-nudge-cli.mjs" --clear 2>/dev/null) || true
  index_text=$(cd "${project_root}" && node "${PLUGIN_ROOT}/scripts/lib/context-index-cli.mjs" --format=text --plugin="${PLUGIN_ROOT}" 2>/dev/null || echo "")
  if [ -n "$index_text" ]; then
    index_escaped=$(escape_for_json "$index_text")
    context_index_context="\\n<DEVFLOW_CONTEXT_INDEX>\\n${index_escaped}\\n</DEVFLOW_CONTEXT_INDEX>\\n"
  fi
fi

# --- Knowledge index (Stage-1: list knowledge-layer docs for the LLM) ---
# SI-1 compliant: projectRoot passed as a positional argument to the helper,
# never interpolated into a `node -e` string.

knowledge_index_context=""
if command -v node >/dev/null 2>&1; then
  knowledge_index_raw=$(cd "${project_root}" && node "${PLUGIN_ROOT}/scripts/lib/print-knowledge-index.mjs" "${project_root}" 2>/dev/null || true)
  if [ -n "$knowledge_index_raw" ]; then
    ki_escaped=$(escape_for_json "$knowledge_index_raw")
    knowledge_index_context="\\n${ki_escaped}\\n"
  fi
fi

# --- docs-mcp-server recommendation (when project has stacks but MCP not configured) ---
# When .context/stacks/manifest.yaml exists (project declares libs) but
# docs-mcp-server is NOT in .mcp.json, emit a recommendation so the user
# knows the modern paradigm (MCP-indexed docs) is available via /devflow config.

docs_mcp_recommendation=""
if [ -f "${project_root}/.context/stacks/manifest.yaml" ] && [ "$docs_mcp_available" = "false" ]; then
  rec_text="docs-mcp-server não configurado. Este projeto declara stacks em .context/stacks/manifest.yaml mas não usa MCP indexing para docs. Para ativar (recomendado): execute \`/devflow config\` e responda 'Sim' à pergunta sobre docs-mcp-server. Após reiniciar o Claude Code, scrape de stacks passa a usar tool MCP em vez de arquivos .md gigantes."
  rec_escaped=$(escape_for_json "$rec_text")
  docs_mcp_recommendation="\\n<DOCS_MCP_RECOMMENDATION>\\n${rec_escaped}\\n</DOCS_MCP_RECOMMENDATION>\\n"
fi

# --- Routines due suggestion (file-based maintenance scheduler) ---
# When .context/routines.json has routines due-to-suggest (respecting snooze +
# 1x/day), emit a suggestion block and mark them suggested. Suggests only —
# never executes. Date comes from DEVFLOW_TODAY (tests) or the real clock.

routines_due_ctx=""
if [ -f "${project_root}/.context/routines.json" ] && command -v node >/dev/null 2>&1; then
  due_ids=$(cd "${project_root}" && node "${PLUGIN_ROOT}/scripts/routines.mjs" due --ids 2>/dev/null || true)
  if [ -n "$due_ids" ]; then
    due_list=$(printf '%s' "$due_ids" | tr '\n' ' ')
    rt_text="Rotinas de manutenção DevFlow vencidas: ${due_list}. Sugira ao usuário rodar \`/devflow:devflow-routines run <id>\` (a routine context-maintenance roda \`/devflow:devflow-doctor\`). Apenas sugira — não execute automaticamente. Para adiar: \`/devflow:devflow-routines snooze <id> <dias>\`."
    rt_escaped=$(escape_for_json "$rt_text")
    routines_due_ctx="\\n<DEVFLOW_ROUTINES_DUE>\\n${rt_escaped}\\n</DEVFLOW_ROUTINES_DUE>\\n"
    # Mark each as suggested so it's not re-surfaced again today (1x/day guard).
    for rid in $due_ids; do
      (cd "${project_root}" && node "${PLUGIN_ROOT}/scripts/routines.mjs" mark-suggested "$rid" >/dev/null 2>&1) || true
    done
  fi
fi

# --- MemPalace auto-recall ---

mempalace_context=""
if [ "$mempalace_available" = "true" ]; then
  # Read mempalace config from .devflow.yaml
  mp_enabled="true"
  mp_budget="500"
  mp_wing="auto"
  mp_auto_recall="true"
  devflow_config="${project_root}/.context/.devflow.yaml"

  if [ -f "$devflow_config" ]; then
    read mp_enabled mp_budget mp_wing mp_auto_recall <<< $(python3 - "$devflow_config" << 'PYEOF'
import sys
try:
    import yaml
    with open(sys.argv[1]) as f:
        data = yaml.safe_load(f) or {}
    mp = data.get('mempalace', {})
    print(str(mp.get('enabled', True)).lower(),
          str(mp.get('budget', 500)),
          str(mp.get('wing', 'auto')),
          str(mp.get('auto_recall', True)).lower())
except:
    print('true 500 auto true')
PYEOF
    )
  fi

  # Sanitize config values from YAML
  mp_budget=$(printf '%s' "$mp_budget" | tr -cd '0-9'); mp_budget=${mp_budget:-500}
  mp_wing=$(printf '%s' "$mp_wing" | tr -cd 'a-zA-Z0-9._-'); mp_wing=${mp_wing:-auto}

  # Resolve wing name
  if [ "$mp_wing" = "auto" ]; then
    mp_wing=$(basename "$project_root")
  fi

  if [ "$mp_enabled" = "true" ] && [ "$mp_auto_recall" = "true" ]; then
    mempalace_recall_instruction="At session start, call the mempalace MCP tool to search for relevant memories. Use wing '${mp_wing}' and limit results to approximately ${mp_budget} tokens (roughly $((mp_budget * 4 / 3)) words). Search based on the current branch name and any active workflow description. Inject results as context for the session."
    mp_escaped=$(escape_for_json "$mempalace_recall_instruction")
    mempalace_context="\\n<MEMPALACE_CONTEXT>\\nMemPalace integration active. Wing: ${mp_wing}. Budget: ${mp_budget} tokens.\\n${mp_escaped}\\n</MEMPALACE_CONTEXT>\\n"
  fi
fi

# --- Grounding mode directive (doc-grounding obrigatório) ---
# When grounding.mode != off in .context/.devflow.yaml, inject a high-priority
# directive: source external-stack facts ONLY from the docs MCP, fail-closed,
# never from training memory. The web hard-block lives in pre-tool-use; this is
# the behavioral protocol. Absent/off → no block (opt-in).

grounding_context=""
grounding_config="${project_root}/.context/.devflow.yaml"
if [ -f "$grounding_config" ]; then
  read g_mode g_server <<< $(python3 - "$grounding_config" << 'PYEOF'
import sys
mode, server = 'off', 'docs-mcp-server'
try:
    in_g = False
    for raw in open(sys.argv[1]):
        line = raw.rstrip('\n'); stripped = line.strip()
        if stripped == 'grounding:':
            in_g = True; continue
        if in_g:
            if line and not line[0].isspace():
                break
            if stripped.startswith('mode:'):
                mode = stripped.split(':', 1)[1].strip().strip('"\'')
            elif stripped.startswith('docsMcpServer:'):
                server = stripped.split(':', 1)[1].strip().strip('"\'')
except Exception:
    pass
print(mode, server)
PYEOF
  )
  g_server=$(printf '%s' "$g_server" | tr -cd 'a-zA-Z0-9._-'); g_server=${g_server:-docs-mcp-server}

  if [ -n "$g_mode" ] && [ "$g_mode" != "off" ]; then
    grounding_instruction="DOC-GROUNDING ATIVO (mode: ${g_mode}). Fonte canonica de fatos de stack: o MCP de documentacao (mcp__${g_server}__search_docs / find_version / list_libraries).
PROTOCOLO para qualquer afirmacao sobre lib/framework/API/versao EXTERNA:
1. Consulte o MCP ANTES de afirmar.
2. Responda CITANDO lib@versao + o trecho retornado.
3. Se o MCP retornar vazio/timeout/erro: em 'docs-only' PARE e diga 'nao ha doc indexada ou o MCP falhou — nao vou responder de memoria de treino', e ofereca /devflow:scrape-stack-batch. Em 'docs-first', so entao complemente, com disclosure explicito 'fonte: conhecimento de treino, nao verificado no MCP'.
ESCOPO: vale para conhecimento de STACK EXTERNO. Raciocinio geral, o codigo DO PROPRIO projeto (verificavel por Read/Grep/Glob) e o contexto da conversa seguem livres.
LIMITE (honestidade): este modo bloqueia ferramentas web (hard, via pre-tool-use) + exige citacao + fail-closed; NAO e trava nos pesos do modelo — e compromisso reforcado por essas barreiras."
    g_escaped=$(escape_for_json "$grounding_instruction")
    grounding_context="\\n<GROUNDING_MODE>\\n${g_escaped}\\n</GROUNDING_MODE>\\n"
  fi
fi

using_devflow_escaped=$(escape_for_json "$using_devflow_content")

# --- Build mode context ---

mode_context="\\n\\n**DevFlow Mode: ${mode}**\\n"
mode_context+="- superpowers: ${superpowers_available}\\n"
mode_context+="- dotcontext MCP: ${dotcontext_mcp}\\n"
mode_context+="- dotcontext CLI: ${dotcontext_cli}\\n"
mode_context+="- dotcontext lite (.context/): ${dotcontext_lite}\\n"
mode_context+="- mempalace: ${mempalace_available}\\n"
mode_context+="- docs-mcp-server: ${docs_mcp_available}\\n"

# --- Mode status announcement (i18n) ---

if [ "$mode" = "full" ]; then
  mode_context+="\\n**STATUS:** ✅ ${MSG_STATUS_FULL}\\n"
elif [ "$mode" = "lite" ]; then
  mode_context+="\\n**STATUS:** ⚠️ ${MSG_STATUS_LITE}\\n"
  mode_context+="${MSG_STATUS_LITE_DETAIL}\\n"
  mode_context+="${MSG_STATUS_LITE_RECOMMEND}\\n"
  if [ "$dotcontext_cli" = "true" ]; then
    mode_context+="${MSG_STATUS_LITE_ACTIVATE_CLI}\\n"
  else
    mode_context+="${MSG_STATUS_LITE_ACTIVATE_FULL}\\n"
  fi
  mode_context+="${MSG_STATUS_LITE_INIT}\\n"
elif [ "$mode" = "minimal" ]; then
  mode_context+="\\n**STATUS:** ⚠️ ${MSG_STATUS_MINIMAL}\\n"
  mode_context+="${MSG_STATUS_MINIMAL_RECOMMEND}\\n"
  mode_context+="${MSG_STATUS_MINIMAL_ACTIVATE}\\n"
fi

mode_context+="\\n**INSTRUÇÃO:** ${MSG_SESSION_INSTRUCTION}\\n"

# --- Language context injection ---

lang_context=$(build_language_context)
mode_context+="\\n**${lang_context}**\\n"
mode_context+="\\n**DevFlow Language:** ${DEVFLOW_LANGUAGE} (${DEVFLOW_LANGUAGE_NAME})\\n"

# --- Sync dotcontext MCP language (if mcp.json exists) ---

if [ -f "${project_root}/.mcp.json" ] && [ -f "${project_root}/.devflow-language" ] || [ -f "${HOME}/.devflow-language" ]; then
  # Map DevFlow locale to dotcontext locale
  case "$DEVFLOW_LANGUAGE" in
    en-US) dc_lang="en" ;;
    pt-BR) dc_lang="pt-BR" ;;
    es-ES) dc_lang="es" ;;
    *) dc_lang="" ;;
  esac

  if [ -n "$dc_lang" ] && [ -f "${project_root}/.mcp.json" ]; then
    python3 -c "
import json, sys
try:
    with open('${project_root}/.mcp.json') as f:
        config = json.load(f)
    dc = config.get('mcpServers', {}).get('dotcontext', {})
    args = dc.get('args', [])
    # Check if --lang already matches
    for i, a in enumerate(args):
        if a in ('--lang', '-l') and i+1 < len(args) and args[i+1] == '${dc_lang}':
            sys.exit(0)  # already synced
    # Remove existing --lang/-l flags
    new_args = []
    skip = False
    for a in args:
        if skip:
            skip = False
            continue
        if a in ('--lang', '-l'):
            skip = True
            continue
        new_args.append(a)
    # Insert --lang before 'mcp'
    idx = new_args.index('mcp') if 'mcp' in new_args else len(new_args)
    new_args.insert(idx, '${dc_lang}')
    new_args.insert(idx, '--lang')
    config['mcpServers']['dotcontext']['args'] = new_args
    with open('${project_root}/.mcp.json', 'w') as f:
        json.dump(config, f, indent=2)
        f.write('\n')
except Exception:
    pass
" 2>/dev/null || true
  fi
fi

mode_escaped=$(escape_for_json "$mode_context")

autonomous_escaped=$(escape_for_json "$autonomous_context")

# ── Instinct recall (gated por N2, bounded, nunca bloqueia) ────────────
# N2 (ADR-005): opt-in é o PISO no YAML (instincts.enabled: true); env só RESTRINGE.
# Injeta o digest DENTRO do session_context (contrato JSON), não como texto solto.
instinct_context=""
INSTINCT_CFG="${project_root}/.context/.devflow.yaml"
if [ "${DEVFLOW_INSTINCTS_ENABLED:-}" != "0" ] && [ "${DEVFLOW_INSTINCT_PROFILE:-}" != "off" ] \
   && [ -n "${CLAUDE_PLUGIN_ROOT:-}" ] && [ -f "$INSTINCT_CFG" ] \
   && awk '/^instincts:[[:space:]]*$/{b=1;next} /^[^[:space:]#]/{b=0} b&&/^[[:space:]]+enabled:[[:space:]]*true[[:space:]]*(#.*)?$/{f=1} END{exit !f}' "$INSTINCT_CFG"; then
  INSTINCT_DIGEST=$(timeout 1 node "${CLAUDE_PLUGIN_ROOT}/scripts/instinct-cli.mjs" recall --max-chars=2000 2>/dev/null || true)
  [ -n "$INSTINCT_DIGEST" ] && instinct_context="$(escape_for_json "$INSTINCT_DIGEST")\n"
fi

session_context="<DEVFLOW_CONTEXT>\nYou have DevFlow installed.\n\n**Below is the full content of your 'devflow:using-devflow' skill — your entry point for the unified development workflow. For all other skills, use the 'Skill' tool:**\n\n${using_devflow_escaped}\n\n${mode_escaped}\n${autonomous_escaped}\n${napkin_context}\n${adr_context}\n${context_index_context}\n${knowledge_index_context}\n${docs_mcp_recommendation}\n${grounding_context}\n${routines_due_ctx}\n${mempalace_context}\n${instinct_context}</DEVFLOW_CONTEXT>"

# --- Output for platform ---

if [ -n "${CURSOR_PLUGIN_ROOT:-}" ]; then
  printf '{\n  "additional_context": "%s"\n}\n' "$session_context"
elif [ -n "${CLAUDE_PLUGIN_ROOT:-}" ]; then
  printf '{\n  "hookSpecificOutput": {\n    "hookEventName": "SessionStart",\n    "additionalContext": "%s"\n  }\n}\n' "$session_context"
else
  printf '{\n  "additional_context": "%s"\n}\n' "$session_context"
fi

# --- OTel span emission (Task 4.3, opt-in via .context/observability.yaml) ---
# No-op when enabled:false (zero overhead, SDK not loaded). Per SI-1, the
# emitter is invoked as a separate file with JSON envelope on stdin —
# never via node -e with interpolation.

if [ -f "${project_root}/.context/observability.yaml" ]; then
  printf '{"event":"devflow.session_start","attributes":{"devflow.session.id":"%s","devflow.context.adrs_indexed":"unknown"}}' \
    "$$" \
    | (cd "${project_root}" && node "${SCRIPT_DIR}/../scripts/lib/otel-cli.mjs") 2>/dev/null || true
fi

exit 0
