#!/usr/bin/env bash
# DevFlow SessionStart hook
# Detects available systems and injects unified context

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
PLUGIN_ROOT="$(cd "${SCRIPT_DIR}/.." && pwd)"

# --- Load i18n ---

source "${SCRIPT_DIR}/i18n.sh"
load_i18n

# --- Mode Detection ---

mode="minimal"
superpowers_available="false"
dotcontext_mcp="false"
dotcontext_cli="false"
dotcontext_lite="false"

# Check superpowers: look in installed_plugins.json (Claude Code plugin system)
installed_plugins="${HOME}/.claude/plugins/installed_plugins.json"
if [ -f "$installed_plugins" ] && grep -q '"superpowers@' "$installed_plugins" 2>/dev/null; then
  superpowers_available="true"
fi

# Fallback: check if superpowers skills directory exists in plugin cache
if [ "$superpowers_available" = "false" ]; then
  for dir in "${HOME}/.claude/plugins/cache"/*/superpowers/*/skills; do
    if [ -d "$dir" ]; then
      superpowers_available="true"
      break
    fi
  done
fi

# Check dotcontext MCP: look for .mcp.json or mcp config referencing dotcontext
project_root="${PWD}"
if [ -f "${project_root}/.mcp.json" ] && grep -q "dotcontext" "${project_root}/.mcp.json" 2>/dev/null; then
  dotcontext_mcp="true"
  mode="full"
elif [ -f "${HOME}/.config/claude/mcp.json" ] && grep -q "dotcontext" "${HOME}/.config/claude/mcp.json" 2>/dev/null; then
  dotcontext_mcp="true"
  mode="full"
fi

# Check mempalace MCP: look for mempalace in .mcp.json or global mcp config
mempalace_available="false"
if [ -f "${project_root}/.mcp.json" ] && grep -q "mempalace" "${project_root}/.mcp.json" 2>/dev/null; then
  mempalace_available="true"
elif [ -f "${HOME}/.config/claude/mcp.json" ] && grep -q "mempalace" "${HOME}/.config/claude/mcp.json" 2>/dev/null; then
  mempalace_available="true"
fi

# Check dotcontext CLI: global install or npx available
if [ "$mode" != "full" ]; then
  if command -v dotcontext >/dev/null 2>&1; then
    dotcontext_cli="true"
  elif command -v npx >/dev/null 2>&1 && npx --yes @dotcontext/cli --version >/dev/null 2>&1; then
    dotcontext_cli="true"
  fi
fi

# Check dotcontext lite: .context/ directory exists
if [ "$mode" != "full" ] && [ -d "${project_root}/.context" ]; then
  dotcontext_lite="true"
  mode="lite"
fi

# --- Detect active autonomous workflow ---

autonomous_context=""
stories_file="${project_root}/.context/workflow/stories.yaml"
if [ -f "$stories_file" ]; then
  # Extract key stats from stories.yaml using grep (no yaml parser needed)
  # Sanitize: strip anything outside safe chars to prevent prompt injection
  sanitize_str() { printf '%s' "$1" | tr -cd 'a-zA-Z0-9 _./:-'; }
  sanitize_int() { printf '%s' "$1" | tr -cd '0-9'; }

  autonomy_mode=$(sanitize_str "$(grep '^autonomy:' "$stories_file" 2>/dev/null | head -1 | sed 's/autonomy: *//' | tr -d '"' || echo "")")
  current_autonomy=$(sanitize_str "$(grep 'current_autonomy:' "$stories_file" 2>/dev/null | head -1 | sed 's/.*current_autonomy: *//' | tr -d '"' || echo "")")
  total=$(sanitize_int "$(grep 'total:' "$stories_file" 2>/dev/null | head -1 | sed 's/.*total: *//' || echo "0")")
  completed=$(sanitize_int "$(grep 'completed:' "$stories_file" 2>/dev/null | head -1 | sed 's/.*completed: *//' || echo "0")")
  escalated=$(sanitize_int "$(grep 'escalated:' "$stories_file" 2>/dev/null | head -2 | tail -1 | sed 's/.*escalated: *//' || echo "0")")
  feature=$(sanitize_str "$(grep '^feature:' "$stories_file" 2>/dev/null | head -1 | sed 's/feature: *//' | tr -d '"' || echo "")")

  # Guard: skip injection if key fields are empty (malformed YAML)
  if [ -n "$autonomy_mode" ] && [ "$autonomy_mode" != "supervised" ] && [ -n "$total" ] && [ "$total" != "0" ]; then
    active_mode="${current_autonomy:-$autonomy_mode}"
    autonomous_context="\\n**AUTONOMOUS WORKFLOW ACTIVE**\\n"
    autonomous_context+="- Feature: ${feature}\\n"
    autonomous_context+="- Mode: ${active_mode}\\n"
    autonomous_context+="- Progress: ${completed}/${total} stories (${escalated} escalated)\\n"
    autonomous_context+="- To resume: say \\\"continue\\\" or invoke devflow:autonomous-loop\\n"
  fi
fi

# --- Read using-devflow skill ---

using_devflow_content=$(cat "${PLUGIN_ROOT}/skills/using-devflow/SKILL.md" 2>&1 || echo "Error reading using-devflow skill")

# --- Escape for JSON ---

escape_for_json() {
    local s="$1"
    s="${s//\\/\\\\}"
    s="${s//\"/\\\"}"
    s="${s//$'\n'/\\n}"
    s="${s//$'\r'/\\r}"
    s="${s//$'\t'/\\t}"
    printf '%s' "$s"
}

# --- Detect and inject napkin runbook ---

napkin_context=""
napkin_file="${project_root}/.context/napkin.md"

if [ -f "$napkin_file" ]; then
  napkin_content=$(cat "$napkin_file" 2>/dev/null || echo "")
  if [ -n "$napkin_content" ]; then
    napkin_escaped=$(escape_for_json "$napkin_content")
    napkin_context="\\n<NAPKIN_RUNBOOK>\\n${napkin_escaped}\\n</NAPKIN_RUNBOOK>\\n"
  fi
elif [ -d "${project_root}/.context" ]; then
  cat > "$napkin_file" << 'NAPKIN_TMPL'
# Napkin Runbook

## Curation Rules
- Re-prioritize on every read.
- Keep recurring, high-value notes only.
- Max 15 items per category, max 7 per agent section.
- Each item includes date + "Do instead".

## Execution & Validation
(empty)

## Shell & Command Reliability
(empty)

## Domain Behavior Guardrails
(empty)

## User Directives
(empty)

## Agent-Specific Notes
<!-- Sections appear on demand: ### agent-name -->
NAPKIN_TMPL
  napkin_content=$(cat "$napkin_file")
  napkin_escaped=$(escape_for_json "$napkin_content")
  napkin_context="\\n<NAPKIN_RUNBOOK>\\n${napkin_escaped}\\n</NAPKIN_RUNBOOK>\\n"
fi

# --- Detect and inject ADR guardrails ---

adr_context=""
adr_dir="${project_root}/.context/docs/adrs"

if [ -f "${adr_dir}/README.md" ]; then
  adr_count=0
  adr_guardrails_content=""

  # Iterate ADR files in sorted order, skipping README
  while IFS= read -r adr_file; do
    [ -f "$adr_file" ] || continue

    # Read status from frontmatter
    adr_status=$(grep -m1 '^status:' "$adr_file" 2>/dev/null | sed 's/^status:[[:space:]]*//' | tr -d '"' | tr -d "'")
    [ "$adr_status" = "Aprovado" ] || continue

    adr_name=$(grep -m1 '^name:' "$adr_file" 2>/dev/null | sed 's/^name:[[:space:]]*//' | tr -d '"' | tr -d "'")
    adr_stack=$(grep -m1 '^stack:' "$adr_file" 2>/dev/null | sed 's/^stack:[[:space:]]*//' | tr -d '"' | tr -d "'")

    # Extract "## Guardrails" section: from the heading to the next "## " heading
    guardrails=$(awk '/^## Guardrails[[:space:]]*$/{flag=1; next} /^## /{flag=0} flag' "$adr_file")

    if [ -n "$guardrails" ]; then
      adr_count=$((adr_count + 1))
      adr_guardrails_content+=$'\n### '"${adr_name}"' (stack: '"${adr_stack}"')'$'\n'"${guardrails}"$'\n'
    fi
  done < <(find "$adr_dir" -maxdepth 1 -type f -name '*.md' ! -name 'README.md' 2>/dev/null | sort)

  if [ "$adr_count" -gt 0 ]; then
    adr_header="Loaded ${adr_count} active ADR(s). These are HARD CONSTRAINTS — apply during brainstorming, design, and implementation. Do not propose alternatives already rejected in ADRs."
    adr_escaped=$(escape_for_json "${adr_header}${adr_guardrails_content}")
    adr_context="\\n<ADR_GUARDRAILS>\\n${adr_escaped}\\n</ADR_GUARDRAILS>\\n"
  fi
fi

# --- MemPalace auto-recall ---

mempalace_context=""
if [ "$mempalace_available" = "true" ]; then
  # Read mempalace config from .devflow.yaml
  mp_enabled="true"
  mp_budget="500"
  mp_wing="auto"
  mp_auto_recall="true"
  devflow_config="${project_root}/.context/.devflow.yaml"

  if [ -f "$devflow_config" ]; then
    read mp_enabled mp_budget mp_wing mp_auto_recall <<< $(python3 - "$devflow_config" << 'PYEOF'
import sys
try:
    import yaml
    with open(sys.argv[1]) as f:
        data = yaml.safe_load(f) or {}
    mp = data.get('mempalace', {})
    print(str(mp.get('enabled', True)).lower(),
          str(mp.get('budget', 500)),
          str(mp.get('wing', 'auto')),
          str(mp.get('auto_recall', True)).lower())
except:
    print('true 500 auto true')
PYEOF
    )
  fi

  # Sanitize config values from YAML
  mp_budget=$(printf '%s' "$mp_budget" | tr -cd '0-9'); mp_budget=${mp_budget:-500}
  mp_wing=$(printf '%s' "$mp_wing" | tr -cd 'a-zA-Z0-9._-'); mp_wing=${mp_wing:-auto}

  # Resolve wing name
  if [ "$mp_wing" = "auto" ]; then
    mp_wing=$(basename "$project_root")
  fi

  if [ "$mp_enabled" = "true" ] && [ "$mp_auto_recall" = "true" ]; then
    mempalace_recall_instruction="At session start, call the mempalace MCP tool to search for relevant memories. Use wing '${mp_wing}' and limit results to approximately ${mp_budget} tokens (roughly $((mp_budget * 4 / 3)) words). Search based on the current branch name and any active workflow description. Inject results as context for the session."
    mp_escaped=$(escape_for_json "$mempalace_recall_instruction")
    mempalace_context="\\n<MEMPALACE_CONTEXT>\\nMemPalace integration active. Wing: ${mp_wing}. Budget: ${mp_budget} tokens.\\n${mp_escaped}\\n</MEMPALACE_CONTEXT>\\n"
  fi
fi

using_devflow_escaped=$(escape_for_json "$using_devflow_content")

# --- Build mode context ---

mode_context="\\n\\n**DevFlow Mode: ${mode}**\\n"
mode_context+="- superpowers: ${superpowers_available}\\n"
mode_context+="- dotcontext MCP: ${dotcontext_mcp}\\n"
mode_context+="- dotcontext CLI: ${dotcontext_cli}\\n"
mode_context+="- dotcontext lite (.context/): ${dotcontext_lite}\\n"
mode_context+="- mempalace: ${mempalace_available}\\n"

# --- Mode status announcement (i18n) ---

if [ "$mode" = "full" ]; then
  mode_context+="\\n**STATUS:** ✅ ${MSG_STATUS_FULL}\\n"
elif [ "$mode" = "lite" ]; then
  mode_context+="\\n**STATUS:** ⚠️ ${MSG_STATUS_LITE}\\n"
  mode_context+="${MSG_STATUS_LITE_DETAIL}\\n"
  mode_context+="${MSG_STATUS_LITE_RECOMMEND}\\n"
  if [ "$dotcontext_cli" = "true" ]; then
    mode_context+="${MSG_STATUS_LITE_ACTIVATE_CLI}\\n"
  else
    mode_context+="${MSG_STATUS_LITE_ACTIVATE_FULL}\\n"
  fi
  mode_context+="${MSG_STATUS_LITE_INIT}\\n"
elif [ "$mode" = "minimal" ]; then
  mode_context+="\\n**STATUS:** ⚠️ ${MSG_STATUS_MINIMAL}\\n"
  mode_context+="${MSG_STATUS_MINIMAL_RECOMMEND}\\n"
  mode_context+="${MSG_STATUS_MINIMAL_ACTIVATE}\\n"
fi

mode_context+="\\n**INSTRUÇÃO:** ${MSG_SESSION_INSTRUCTION}\\n"

# --- Language context injection ---

lang_context=$(build_language_context)
mode_context+="\\n**${lang_context}**\\n"
mode_context+="\\n**DevFlow Language:** ${DEVFLOW_LANGUAGE} (${DEVFLOW_LANGUAGE_NAME})\\n"

# --- Sync dotcontext MCP language (if mcp.json exists) ---

if [ -f "${project_root}/.mcp.json" ] && [ -f "${project_root}/.devflow-language" ] || [ -f "${HOME}/.devflow-language" ]; then
  # Map DevFlow locale to dotcontext locale
  case "$DEVFLOW_LANGUAGE" in
    en-US) dc_lang="en" ;;
    pt-BR) dc_lang="pt-BR" ;;
    es-ES) dc_lang="es" ;;
    *) dc_lang="" ;;
  esac

  if [ -n "$dc_lang" ] && [ -f "${project_root}/.mcp.json" ]; then
    python3 -c "
import json, sys
try:
    with open('${project_root}/.mcp.json') as f:
        config = json.load(f)
    dc = config.get('mcpServers', {}).get('dotcontext', {})
    args = dc.get('args', [])
    # Check if --lang already matches
    for i, a in enumerate(args):
        if a in ('--lang', '-l') and i+1 < len(args) and args[i+1] == '${dc_lang}':
            sys.exit(0)  # already synced
    # Remove existing --lang/-l flags
    new_args = []
    skip = False
    for a in args:
        if skip:
            skip = False
            continue
        if a in ('--lang', '-l'):
            skip = True
            continue
        new_args.append(a)
    # Insert --lang before 'mcp'
    idx = new_args.index('mcp') if 'mcp' in new_args else len(new_args)
    new_args.insert(idx, '${dc_lang}')
    new_args.insert(idx, '--lang')
    config['mcpServers']['dotcontext']['args'] = new_args
    with open('${project_root}/.mcp.json', 'w') as f:
        json.dump(config, f, indent=2)
        f.write('\n')
except Exception:
    pass
" 2>/dev/null || true
  fi
fi

mode_escaped=$(escape_for_json "$mode_context")

autonomous_escaped=$(escape_for_json "$autonomous_context")
session_context="<DEVFLOW_CONTEXT>\nYou have DevFlow installed.\n\n**Below is the full content of your 'devflow:using-devflow' skill — your entry point for the unified development workflow. For all other skills, use the 'Skill' tool:**\n\n${using_devflow_escaped}\n\n${mode_escaped}\n${autonomous_escaped}\n${napkin_context}\n${adr_context}\n${mempalace_context}\n</DEVFLOW_CONTEXT>"

# --- Output for platform ---

if [ -n "${CURSOR_PLUGIN_ROOT:-}" ]; then
  printf '{\n  "additional_context": "%s"\n}\n' "$session_context"
elif [ -n "${CLAUDE_PLUGIN_ROOT:-}" ]; then
  printf '{\n  "hookSpecificOutput": {\n    "hookEventName": "SessionStart",\n    "additionalContext": "%s"\n  }\n}\n' "$session_context"
else
  printf '{\n  "additional_context": "%s"\n}\n' "$session_context"
fi

exit 0
