#!/usr/bin/env bash
# DevFlow PreToolUse hook — Branch Protection Gate
# Blocks Edit/Write on protected branches.
# Allows workflow files (handoff, checkpoints, plans, .context/workflow/).
# On block: instructs LLM to invoke devflow:git-strategy automatically.
#
# Config source: .context/.devflow.yaml (generated by /devflow config)
# If config is missing, blocks with MSG_NO_CONFIG instruction.

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
PLUGIN_ROOT="$(cd "${SCRIPT_DIR}/.." && pwd)"

# --- Load i18n ---

source "${SCRIPT_DIR}/i18n.sh"
load_i18n

# --- Read stdin (Claude Code passes tool context as JSON) ---

INPUT=$(cat)

TOOL_NAME=$(printf '%s' "$INPUT" | python3 -c "
import json, sys
d = json.load(sys.stdin)
print(d.get('tool_name', ''))
" 2>/dev/null || echo "")

CWD=$(printf '%s' "$INPUT" | python3 -c "
import json, sys
d = json.load(sys.stdin)
print(d.get('cwd', ''))
" 2>/dev/null || echo "")

# --- Permissions evaluator (Task 3.2, SI compliance — runs FIRST) ---
# Loads .context/permissions.yaml and evaluates deny → allow → mode → callback.
# A 'deny' decision exits the hook immediately with permissionDecision=deny;
# 'allow' continues to existing branch protection (defense-in-depth);
# 'prompt' falls through to the legacy logic (no behavior change for users
# who haven't configured permissions.yaml — empty config returns 'prompt').
#
# Uses event.cwd (not PWD) so the hook reads the permissions.yaml of the
# user's project, not the plugin install dir.

PERMS_DIR="${CWD:-$PWD}"
if [ -f "${PERMS_DIR}/.context/permissions.yaml" ]; then
  EVENT_PATH=$(printf '%s' "$INPUT" | python3 -c "
import json, sys
d = json.load(sys.stdin)
ti = d.get('tool_input', {})
print(ti.get('file_path') or ti.get('file') or ti.get('path') or '')
" 2>/dev/null || echo "")

  EVENT_CMD=$(printf '%s' "$INPUT" | python3 -c "
import json, sys
d = json.load(sys.stdin)
ti = d.get('tool_input', {})
print(ti.get('command', ''))
" 2>/dev/null || echo "")

  PERM_INPUT=$(printf '%s' "$INPUT" | python3 -c "
import json, sys
d = json.load(sys.stdin)
ti = d.get('tool_input', {})
ev = {
    'tool': d.get('tool_name', ''),
    'path': ti.get('file_path') or ti.get('file') or ti.get('path') or None,
    'command': ti.get('command', '') or None,
}
print(json.dumps(ev))
" 2>/dev/null || echo "{}")

  # Run the CLI with cwd set to the user's project so permissions-evaluator
  # loads the correct .context/permissions.yaml.
  PERM_OUT=$(printf '%s' "$PERM_INPUT" | (cd "${PERMS_DIR}" && node "${PLUGIN_ROOT}/scripts/lib/permissions-cli.mjs") 2>/dev/null || echo "")

  if [ -n "$PERM_OUT" ]; then
    PERM_DECISION=$(printf '%s' "$PERM_OUT" | python3 -c "
import json, sys
try: print(json.load(sys.stdin).get('decision', ''))
except: print('')
" 2>/dev/null || echo "")

    if [ "$PERM_DECISION" = "deny" ]; then
      # Inline JSON escape (escape_for_json is defined later in the script)
      REASON_ESCAPED=$(printf '%s' "$PERM_OUT" | python3 -c "
import json, sys
try:
    reason = json.load(sys.stdin).get('reason', 'permissions.yaml denied')
except:
    reason = 'permissions.yaml denied'
prefixed = f'[devflow permissions.yaml] {reason}'
# JSON-escape into a string-safe form (drops the surrounding quotes)
print(json.dumps(prefixed)[1:-1])
" 2>/dev/null || echo "permissions.yaml denied")
      printf '{\n  "hookSpecificOutput": {\n    "hookEventName": "PreToolUse",\n    "permissionDecision": "deny",\n    "permissionDecisionReason": "%s"\n  }\n}\n' "$REASON_ESCAPED"
      # OTel: emit deny span before exiting (4.3)
      if [ -f "${PERMS_DIR}/.context/observability.yaml" ]; then
        printf '{"event":"devflow.permission.deny","attributes":{"devflow.permission.decision":"deny","gen_ai.tool.name":"%s"}}' "$TOOL_NAME" \
          | (cd "${PERMS_DIR}" && node "${PLUGIN_ROOT}/scripts/lib/otel-cli.mjs") 2>/dev/null || true
      fi
      exit 0
    fi
  fi
fi

# --- Grounding mode: block internet tools when doc-grounding is active ---
# Self-contained, web-tool-only branch placed BEFORE the Edit/Write gate so it
# can act on WebSearch/WebFetch (which the gate below exits 0 on). It NEVER
# touches the branch-protection path (that runs only for Edit/Write). Grounding
# absent/off → no-op (opt-in). Fail-open on parse error (does not block).
case "$TOOL_NAME" in
  WebSearch|WebFetch)
    GROUNDING_CONFIG="${CWD:-$PWD}/.context/.devflow.yaml"
    if [ -f "$GROUNDING_CONFIG" ]; then
      GROUNDING_REASON=$(python3 - "$GROUNDING_CONFIG" "$TOOL_NAME" << 'PYEOF'
import sys, json
fp, tool = sys.argv[1], sys.argv[2]
mode, block_web, server = 'off', True, 'docs-mcp-server'
try:
    in_g = False
    for raw in open(fp):
        line = raw.rstrip('\n')
        stripped = line.strip()
        if stripped == 'grounding:':
            in_g = True
            continue
        if in_g:
            # leave the section at the first non-indented, non-empty line
            if line and not line[0].isspace():
                break
            if stripped.startswith('mode:'):
                mode = stripped.split(':', 1)[1].strip().strip('"\'')
            elif stripped.startswith('blockWeb:'):
                block_web = stripped.split(':', 1)[1].strip().lower() != 'false'
            elif stripped.startswith('docsMcpServer:'):
                server = stripped.split(':', 1)[1].strip().strip('"\'')
except Exception:
    sys.exit(0)  # fail-open: never block on parse error (grounding is opt-in)
if mode != 'off' and block_web:
    reason = ("[devflow grounding:%s] Ferramenta de internet '%s' bloqueada — o modo "
              "doc-grounding exige que fatos de stack (lib/framework/API/versão) venham "
              "SÓ do MCP de documentação. Use mcp__%s__search_docs / find_version. Se a "
              "doc não estiver indexada, rode /devflow:scrape-stack-batch ou declare a "
              "incerteza — NUNCA responda de memória de treino." % (mode, tool, server))
    print(json.dumps(reason)[1:-1])  # JSON-escaped; surrounding quotes stripped
PYEOF
)
      if [ -n "$GROUNDING_REASON" ]; then
        printf '{\n  "hookSpecificOutput": {\n    "hookEventName": "PreToolUse",\n    "permissionDecision": "deny",\n    "permissionDecisionReason": "%s"\n  }\n}\n' "$GROUNDING_REASON"
        exit 0
      fi
    fi
    ;;
esac

# --- Only act on Edit and Write (legacy branch-protection logic) ---

if [ "$TOOL_NAME" != "Edit" ] && [ "$TOOL_NAME" != "Write" ]; then
  exit 0
fi

# --- Extract file path ---

FILE_PATH=$(printf '%s' "$INPUT" | python3 -c "
import json, sys
d = json.load(sys.stdin)
ti = d.get('tool_input', {})
print(ti.get('file_path', ti.get('file', '')))
" 2>/dev/null || echo "")

# --- Stage-2: inject on-demand knowledge bodies relevant to the edited file ---
# Emits a <KNOWLEDGE_ONDEMAND> block with bodies of relevant on-demand knowledge docs.
# Guard with || true — never blocks the hook. Runs before branch-protection checks
# so context is always surfaced even when the hook later denies/asks on the edit.

PROJECT_ROOT="${CWD:-$PWD}"
if [ -n "$FILE_PATH" ] && [ -f "${PLUGIN_ROOT}/scripts/lib/print-knowledge-bodies.mjs" ]; then
  node "${PLUGIN_ROOT}/scripts/lib/print-knowledge-bodies.mjs" "${PROJECT_ROOT}" "${FILE_PATH}" 2>/dev/null || true
fi

# --- Allow workflow/infrastructure files on any branch ---
# These are operational files, not project code.

if [ -n "$FILE_PATH" ]; then
  case "$FILE_PATH" in
    # Handoff and checkpoint files
    */.context/workflow/.checkpoint/*)
      exit 0
      ;;
    # Workflow state files
    */.context/workflow/*)
      exit 0
      ;;
    # Plans (PREVC workflow plans)
    */.context/plans/*)
      exit 0
      ;;
    # Context docs (sync updates these)
    */.context/docs/*)
      exit 0
      ;;
    # Context agents and skills (sync/init updates these)
    */.context/agents/*)
      exit 0
      ;;
    */.context/skills/*)
      exit 0
      ;;
    # Design specs and superpowers plans
    */docs/superpowers/*)
      exit 0
      ;;
    */docs/specs/*)
      exit 0
      ;;
    # DevFlow config file (config skill needs to write this)
    */.context/.devflow.yaml)
      exit 0
      ;;
  esac
fi

# --- Get current branch ---

if [ -n "$CWD" ]; then
  BRANCH=$(git -C "$CWD" rev-parse --abbrev-ref HEAD 2>/dev/null || echo "")
else
  BRANCH=$(git rev-parse --abbrev-ref HEAD 2>/dev/null || echo "")
fi

# If we can't determine branch, allow (don't block on git errors)
if [ -z "$BRANCH" ]; then
  exit 0
fi

# --- Escape for JSON (needed for deny responses) ---

escape_for_json() {
    local s="$1"
    s="${s//\\/\\\\}"
    s="${s//\"/\\\"}"
    s="${s//$'\n'/\\n}"
    s="${s//$'\r'/\\r}"
    s="${s//$'\t'/\\t}"
    printf '%s' "$s"
}

# --- Non-project paths (auto-memory, napkin) ---
# These are NOT project source code: auto-memory lives outside the repo
# (~/.claude/projects/*/memory/*) and the curated napkin is operational
# (.context/napkin.md). They must never be hard-denied by the branch gate —
# at most they get an ASK so the user confirms (avoids silent changes).
# MemPalace is reached via its MCP server (mcp__mempalace__*), not Edit/Write,
# so it is never intercepted by this hook.
is_nonproject_path() {
  case "$1" in
    */.claude/projects/*/memory/*|*/.context/napkin.md) return 0 ;;
    *) return 1 ;;
  esac
}

emit_ask_nonproject() {
  local fp="$1" br="$2" ask_reason reason_escaped
  ask_reason=$(render_msg "$MSG_ASK_HEADER" "file_path=${fp}" "branch=${br}")
  reason_escaped=$(escape_for_json "$ask_reason")
  printf '{\n  "hookSpecificOutput": {\n    "hookEventName": "PreToolUse",\n    "permissionDecision": "ask",\n    "permissionDecisionReason": "%s"\n  }\n}\n' "$reason_escaped"
}

# --- Also check: is the file being edited inside the plugin itself? ---

PLUGIN_ROOT_CHECK="${CLAUDE_PLUGIN_ROOT:-}"
if [ -n "$PLUGIN_ROOT_CHECK" ] && [ -n "$FILE_PATH" ]; then
  case "$FILE_PATH" in
    "$PLUGIN_ROOT_CHECK"*)
      exit 0
      ;;
  esac
fi

# --- Read .context/.devflow.yaml ---
# Resolve the project root with the same ${CWD:-$PWD} fallback used by the
# permissions (L46), grounding (L115) and project-root (L178) blocks, and by the
# branch-detection block below (L227-231). When the harness omits cwd in the
# PreToolUse event, $CWD is empty and the hook's own $PWD is the project root —
# so the config is still located. Without this fallback the gate wrongly concludes
# "no config" and denies every project edit even on a non-protected branch.

DEVFLOW_CONFIG="${CWD:-$PWD}/.context/.devflow.yaml"

# If no config exists → DENY with config instruction.
# EXCEPTION: non-project files (auto-memory, napkin) are never hard-denied,
# even when cwd/config is unavailable (e.g. cwd arrives empty for a Write
# outside the workspace). Emit ASK so the user still confirms.
if [ -z "$DEVFLOW_CONFIG" ] || [ ! -f "$DEVFLOW_CONFIG" ]; then
  if is_nonproject_path "$FILE_PATH"; then
    emit_ask_nonproject "$FILE_PATH" "$BRANCH"
    exit 0
  fi
  REASON_ESCAPED=$(escape_for_json "$MSG_NO_CONFIG")
  printf '{\n  "hookSpecificOutput": {\n    "hookEventName": "PreToolUse",\n    "permissionDecision": "deny",\n    "permissionDecisionReason": "%s"\n  }\n}\n' "$REASON_ESCAPED"
  exit 0
fi

# --- Parse git config from YAML ---

read_yaml_field() {
  local file="$1" field="$2"
  python3 - "$file" "$field" << 'PYEOF'
import sys
file_path, field_name = sys.argv[1], sys.argv[2]
try:
    import yaml
    with open(file_path) as f:
        data = yaml.safe_load(f)
    git = data.get('git', {})
    val = git.get(field_name, '')
    if isinstance(val, list):
        print(' '.join(str(v) for v in val))
    elif isinstance(val, bool):
        print(str(val).lower())
    elif isinstance(val, dict):
        import json
        print(json.dumps(val))
    else:
        print(str(val))
except ImportError:
    # Fallback: line-by-line parse for simple YAML (no PyYAML).
    # Handles scalar values and [list] syntax. Does NOT handle nested dicts.
    import re
    in_git = False
    for line in open(file_path):
        stripped = line.strip()
        if stripped == 'git:':
            in_git = True
            continue
        if in_git and not line.startswith(' ') and not line.startswith('\t') and stripped:
            break
        if in_git and field_name + ':' in stripped:
            match = re.match(r'\s*' + re.escape(field_name) + r':\s*(.*)', stripped)
            if match:
                val = match.group(1).strip()
                if val.startswith('[') and val.endswith(']'):
                    val = val[1:-1].replace(',', ' ').replace('"', '').replace("'", '')
                print(val)
                break
    else:
        # for/else: prints empty when field not found (loop completed without break)
        print('')
PYEOF
}

GIT_STRATEGY=$(read_yaml_field "$DEVFLOW_CONFIG" "strategy")
BRANCH_PROTECTION=$(read_yaml_field "$DEVFLOW_CONFIG" "branchProtection")
PROTECTED_BRANCHES=$(read_yaml_field "$DEVFLOW_CONFIG" "protectedBranches")

# --- Apply strategy rules ---

# trunk-based: no protection, allow everything
if [ "$GIT_STRATEGY" = "trunk-based" ]; then
  exit 0
fi

# branchProtection explicitly disabled
if [ "$BRANCH_PROTECTION" = "false" ]; then
  exit 0
fi

# --- Check if current branch is protected ---

IS_PROTECTED=false
for pb in $PROTECTED_BRANCHES; do
  if [ "$BRANCH" = "$pb" ]; then
    IS_PROTECTED=true
    break
  fi
done

if [ "$IS_PROTECTED" = "false" ]; then
  exit 0
fi

# --- ASK: on protected branch, editing confirmable paths (memory/napkin) ---
# Non-project files: auto-memory (outside the repo) and curated napkin (inside .context/).
# Emit permissionDecision=ask so Claude Code prompts the user per edit.

if [ -n "$FILE_PATH" ] && is_nonproject_path "$FILE_PATH"; then
  emit_ask_nonproject "$FILE_PATH" "$BRANCH"
  exit 0
fi

# --- BLOCK: on protected branch, editing project source code ---

blocked_header=$(render_msg "$MSG_BLOCKED_HEADER" "branch=${BRANCH}")
blocked_file=$(render_msg "$MSG_BLOCKED_FILE" "file_path=${FILE_PATH}")

REASON="${blocked_header}

${MSG_BLOCKED_ACTION}

${blocked_file}

${MSG_BLOCKED_NOTE}"

REASON_ESCAPED=$(escape_for_json "$REASON")

printf '{\n  "hookSpecificOutput": {\n    "hookEventName": "PreToolUse",\n    "permissionDecision": "deny",\n    "permissionDecisionReason": "%s"\n  }\n}\n' "$REASON_ESCAPED"

exit 0
