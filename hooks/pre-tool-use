#!/usr/bin/env bash
# DevFlow PreToolUse hook — Branch Protection Gate
# Blocks Edit/Write on protected branches.
# Allows workflow files (handoff, checkpoints, plans, .context/workflow/).
# On block: instructs LLM to invoke devflow:git-strategy automatically.
#
# Protected branches default: main, master, develop
# Override via: .context/docs/development-workflow.md (protectedBranches field)

set -euo pipefail

# --- Read stdin (Claude Code passes tool context as JSON) ---

INPUT=$(cat)

TOOL_NAME=$(printf '%s' "$INPUT" | python3 -c "
import json, sys
d = json.load(sys.stdin)
print(d.get('tool_name', ''))
" 2>/dev/null || echo "")

CWD=$(printf '%s' "$INPUT" | python3 -c "
import json, sys
d = json.load(sys.stdin)
print(d.get('cwd', ''))
" 2>/dev/null || echo "")

# --- Only act on Edit and Write ---

if [ "$TOOL_NAME" != "Edit" ] && [ "$TOOL_NAME" != "Write" ]; then
  exit 0
fi

# --- Extract file path ---

FILE_PATH=$(printf '%s' "$INPUT" | python3 -c "
import json, sys
d = json.load(sys.stdin)
ti = d.get('tool_input', {})
print(ti.get('file_path', ti.get('file', '')))
" 2>/dev/null || echo "")

# --- Allow workflow/infrastructure files on any branch ---
# These are operational files, not project code.

if [ -n "$FILE_PATH" ]; then
  case "$FILE_PATH" in
    # Handoff and checkpoint files
    */.context/workflow/.checkpoint/*)
      exit 0
      ;;
    # Workflow state files
    */.context/workflow/*)
      exit 0
      ;;
    # Plans (PREVC workflow plans)
    */.context/plans/*)
      exit 0
      ;;
    # Context docs (sync updates these)
    */.context/docs/*)
      exit 0
      ;;
    # Context agents and skills (sync/init updates these)
    */.context/agents/*)
      exit 0
      ;;
    */.context/skills/*)
      exit 0
      ;;
    # Design specs and superpowers plans
    */docs/superpowers/*)
      exit 0
      ;;
    */docs/specs/*)
      exit 0
      ;;
  esac
fi

# --- Get current branch ---

if [ -n "$CWD" ]; then
  BRANCH=$(git -C "$CWD" rev-parse --abbrev-ref HEAD 2>/dev/null || echo "")
else
  BRANCH=$(git rev-parse --abbrev-ref HEAD 2>/dev/null || echo "")
fi

# If we can't determine branch, allow (don't block on git errors)
if [ -z "$BRANCH" ]; then
  exit 0
fi

# --- Determine protected branches ---

PROTECTED_BRANCHES="main master develop"

# Try reading from project config
WORKFLOW_FILE=""
if [ -n "$CWD" ]; then
  WORKFLOW_FILE="$CWD/.context/docs/development-workflow.md"
fi

if [ -n "$WORKFLOW_FILE" ] && [ -f "$WORKFLOW_FILE" ]; then
  custom_protected=$(grep -i 'protectedBranches' "$WORKFLOW_FILE" 2>/dev/null \
    | sed 's/.*protectedBranches[[:space:]]*:[[:space:]]*//' \
    | tr ',' ' ' \
    | tr -d '[]"' \
    | xargs 2>/dev/null || echo "")
  if [ -n "$custom_protected" ]; then
    PROTECTED_BRANCHES="$custom_protected"
  fi
fi

# --- Check if current branch is protected ---

IS_PROTECTED=false
for pb in $PROTECTED_BRANCHES; do
  if [ "$BRANCH" = "$pb" ]; then
    IS_PROTECTED=true
    break
  fi
done

if [ "$IS_PROTECTED" = "false" ]; then
  exit 0
fi

# --- Also check: is the file being edited inside the plugin itself? ---

PLUGIN_ROOT="${CLAUDE_PLUGIN_ROOT:-}"
if [ -n "$PLUGIN_ROOT" ] && [ -n "$FILE_PATH" ]; then
  case "$FILE_PATH" in
    "$PLUGIN_ROOT"*)
      exit 0
      ;;
  esac
fi

# --- BLOCK: on protected branch, editing project source code ---

escape_for_json() {
    local s="$1"
    s="${s//\\/\\\\}"
    s="${s//\"/\\\"}"
    s="${s//$'\n'/\\n}"
    s="${s//$'\r'/\\r}"
    s="${s//$'\t'/\\t}"
    printf '%s' "$s"
}

REASON="BLOQUEADO: Você está na branch protegida '${BRANCH}'. Não é permitido editar código do projeto diretamente nesta branch.

AÇÃO AUTOMÁTICA OBRIGATÓRIA:
Invoque o skill devflow:git-strategy AGORA usando: Skill({ skill: \"devflow:git-strategy\" })
O skill vai perguntar ao usuário o tipo de branch e criar o isolamento automaticamente.
Após criar a branch, retente a edição.

Arquivo bloqueado: ${FILE_PATH}

NOTA: Arquivos em .context/ (workflow, checkpoints, plans, docs, agents, skills) e docs/superpowers/ são permitidos em qualquer branch."

REASON_ESCAPED=$(escape_for_json "$REASON")

printf '{\n  "hookSpecificOutput": {\n    "hookEventName": "PreToolUse",\n    "permissionDecision": "deny",\n    "permissionDecisionReason": "%s"\n  }\n}\n' "$REASON_ESCAPED"

exit 0
