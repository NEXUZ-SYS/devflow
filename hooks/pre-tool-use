#!/usr/bin/env bash
# DevFlow PreToolUse hook — Branch Protection Gate
# Blocks Edit/Write on protected branches.
# Allows workflow files (handoff, checkpoints, plans, .context/workflow/).
# On block: instructs LLM to invoke devflow:git-strategy automatically.
#
# Config source: .context/.devflow.yaml (generated by /devflow config)
# If config is missing, blocks with MSG_NO_CONFIG instruction.

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
PLUGIN_ROOT="$(cd "${SCRIPT_DIR}/.." && pwd)"

# --- Load i18n ---

source "${SCRIPT_DIR}/i18n.sh"
load_i18n

# --- Read stdin (Claude Code passes tool context as JSON) ---

INPUT=$(cat)

TOOL_NAME=$(printf '%s' "$INPUT" | python3 -c "
import json, sys
d = json.load(sys.stdin)
print(d.get('tool_name', ''))
" 2>/dev/null || echo "")

CWD=$(printf '%s' "$INPUT" | python3 -c "
import json, sys
d = json.load(sys.stdin)
print(d.get('cwd', ''))
" 2>/dev/null || echo "")

# --- Permissions evaluator (Task 3.2, SI compliance — runs FIRST) ---
# Loads .context/permissions.yaml and evaluates deny → allow → mode → callback.
# A 'deny' decision exits the hook immediately with permissionDecision=deny;
# 'allow' continues to existing branch protection (defense-in-depth);
# 'prompt' falls through to the legacy logic (no behavior change for users
# who haven't configured permissions.yaml — empty config returns 'prompt').
#
# Uses event.cwd (not PWD) so the hook reads the permissions.yaml of the
# user's project, not the plugin install dir.

PERMS_DIR="${CWD:-$PWD}"
if [ -f "${PERMS_DIR}/.context/permissions.yaml" ]; then
  EVENT_PATH=$(printf '%s' "$INPUT" | python3 -c "
import json, sys
d = json.load(sys.stdin)
ti = d.get('tool_input', {})
print(ti.get('file_path') or ti.get('file') or ti.get('path') or '')
" 2>/dev/null || echo "")

  EVENT_CMD=$(printf '%s' "$INPUT" | python3 -c "
import json, sys
d = json.load(sys.stdin)
ti = d.get('tool_input', {})
print(ti.get('command', ''))
" 2>/dev/null || echo "")

  PERM_INPUT=$(printf '%s' "$INPUT" | python3 -c "
import json, sys
d = json.load(sys.stdin)
ti = d.get('tool_input', {})
ev = {
    'tool': d.get('tool_name', ''),
    'path': ti.get('file_path') or ti.get('file') or ti.get('path') or None,
    'command': ti.get('command', '') or None,
}
print(json.dumps(ev))
" 2>/dev/null || echo "{}")

  # Run the CLI with cwd set to the user's project so permissions-evaluator
  # loads the correct .context/permissions.yaml.
  PERM_OUT=$(printf '%s' "$PERM_INPUT" | (cd "${PERMS_DIR}" && node "${PLUGIN_ROOT}/scripts/lib/permissions-cli.mjs") 2>/dev/null || echo "")

  if [ -n "$PERM_OUT" ]; then
    PERM_DECISION=$(printf '%s' "$PERM_OUT" | python3 -c "
import json, sys
try: print(json.load(sys.stdin).get('decision', ''))
except: print('')
" 2>/dev/null || echo "")

    if [ "$PERM_DECISION" = "deny" ]; then
      # Inline JSON escape (escape_for_json is defined later in the script)
      REASON_ESCAPED=$(printf '%s' "$PERM_OUT" | python3 -c "
import json, sys
try:
    reason = json.load(sys.stdin).get('reason', 'permissions.yaml denied')
except:
    reason = 'permissions.yaml denied'
prefixed = f'[devflow permissions.yaml] {reason}'
# JSON-escape into a string-safe form (drops the surrounding quotes)
print(json.dumps(prefixed)[1:-1])
" 2>/dev/null || echo "permissions.yaml denied")
      printf '{\n  "hookSpecificOutput": {\n    "hookEventName": "PreToolUse",\n    "permissionDecision": "deny",\n    "permissionDecisionReason": "%s"\n  }\n}\n' "$REASON_ESCAPED"
      # OTel: emit deny span before exiting (4.3)
      if [ -f "${PERMS_DIR}/.context/observability.yaml" ]; then
        printf '{"event":"devflow.permission.deny","attributes":{"devflow.permission.decision":"deny","gen_ai.tool.call.id":"%s"}}' "$TOOL_NAME" \
          | (cd "${PERMS_DIR}" && node "${PLUGIN_ROOT}/scripts/lib/otel-cli.mjs") 2>/dev/null || true
      fi
      exit 0
    fi
  fi
fi

# --- Only act on Edit and Write (legacy branch-protection logic) ---

if [ "$TOOL_NAME" != "Edit" ] && [ "$TOOL_NAME" != "Write" ]; then
  exit 0
fi

# --- Extract file path ---

FILE_PATH=$(printf '%s' "$INPUT" | python3 -c "
import json, sys
d = json.load(sys.stdin)
ti = d.get('tool_input', {})
print(ti.get('file_path', ti.get('file', '')))
" 2>/dev/null || echo "")

# --- Allow workflow/infrastructure files on any branch ---
# These are operational files, not project code.

if [ -n "$FILE_PATH" ]; then
  case "$FILE_PATH" in
    # Handoff and checkpoint files
    */.context/workflow/.checkpoint/*)
      exit 0
      ;;
    # Workflow state files
    */.context/workflow/*)
      exit 0
      ;;
    # Plans (PREVC workflow plans)
    */.context/plans/*)
      exit 0
      ;;
    # Context docs (sync updates these)
    */.context/docs/*)
      exit 0
      ;;
    # Context agents and skills (sync/init updates these)
    */.context/agents/*)
      exit 0
      ;;
    */.context/skills/*)
      exit 0
      ;;
    # Design specs and superpowers plans
    */docs/superpowers/*)
      exit 0
      ;;
    */docs/specs/*)
      exit 0
      ;;
    # DevFlow config file (config skill needs to write this)
    */.context/.devflow.yaml)
      exit 0
      ;;
  esac
fi

# --- Get current branch ---

if [ -n "$CWD" ]; then
  BRANCH=$(git -C "$CWD" rev-parse --abbrev-ref HEAD 2>/dev/null || echo "")
else
  BRANCH=$(git rev-parse --abbrev-ref HEAD 2>/dev/null || echo "")
fi

# If we can't determine branch, allow (don't block on git errors)
if [ -z "$BRANCH" ]; then
  exit 0
fi

# --- Escape for JSON (needed for deny responses) ---

escape_for_json() {
    local s="$1"
    s="${s//\\/\\\\}"
    s="${s//\"/\\\"}"
    s="${s//$'\n'/\\n}"
    s="${s//$'\r'/\\r}"
    s="${s//$'\t'/\\t}"
    printf '%s' "$s"
}

# --- Also check: is the file being edited inside the plugin itself? ---

PLUGIN_ROOT_CHECK="${CLAUDE_PLUGIN_ROOT:-}"
if [ -n "$PLUGIN_ROOT_CHECK" ] && [ -n "$FILE_PATH" ]; then
  case "$FILE_PATH" in
    "$PLUGIN_ROOT_CHECK"*)
      exit 0
      ;;
  esac
fi

# --- Read .context/.devflow.yaml ---

DEVFLOW_CONFIG=""
if [ -n "$CWD" ]; then
  DEVFLOW_CONFIG="$CWD/.context/.devflow.yaml"
fi

# If no config exists → DENY with config instruction
if [ -z "$DEVFLOW_CONFIG" ] || [ ! -f "$DEVFLOW_CONFIG" ]; then
  REASON_ESCAPED=$(escape_for_json "$MSG_NO_CONFIG")
  printf '{\n  "hookSpecificOutput": {\n    "hookEventName": "PreToolUse",\n    "permissionDecision": "deny",\n    "permissionDecisionReason": "%s"\n  }\n}\n' "$REASON_ESCAPED"
  exit 0
fi

# --- Parse git config from YAML ---

read_yaml_field() {
  local file="$1" field="$2"
  python3 - "$file" "$field" << 'PYEOF'
import sys
file_path, field_name = sys.argv[1], sys.argv[2]
try:
    import yaml
    with open(file_path) as f:
        data = yaml.safe_load(f)
    git = data.get('git', {})
    val = git.get(field_name, '')
    if isinstance(val, list):
        print(' '.join(str(v) for v in val))
    elif isinstance(val, bool):
        print(str(val).lower())
    elif isinstance(val, dict):
        import json
        print(json.dumps(val))
    else:
        print(str(val))
except ImportError:
    # Fallback: line-by-line parse for simple YAML (no PyYAML).
    # Handles scalar values and [list] syntax. Does NOT handle nested dicts.
    import re
    in_git = False
    for line in open(file_path):
        stripped = line.strip()
        if stripped == 'git:':
            in_git = True
            continue
        if in_git and not line.startswith(' ') and not line.startswith('\t') and stripped:
            break
        if in_git and field_name + ':' in stripped:
            match = re.match(r'\s*' + re.escape(field_name) + r':\s*(.*)', stripped)
            if match:
                val = match.group(1).strip()
                if val.startswith('[') and val.endswith(']'):
                    val = val[1:-1].replace(',', ' ').replace('"', '').replace("'", '')
                print(val)
                break
    else:
        # for/else: prints empty when field not found (loop completed without break)
        print('')
PYEOF
}

GIT_STRATEGY=$(read_yaml_field "$DEVFLOW_CONFIG" "strategy")
BRANCH_PROTECTION=$(read_yaml_field "$DEVFLOW_CONFIG" "branchProtection")
PROTECTED_BRANCHES=$(read_yaml_field "$DEVFLOW_CONFIG" "protectedBranches")

# --- Apply strategy rules ---

# trunk-based: no protection, allow everything
if [ "$GIT_STRATEGY" = "trunk-based" ]; then
  exit 0
fi

# branchProtection explicitly disabled
if [ "$BRANCH_PROTECTION" = "false" ]; then
  exit 0
fi

# --- Check if current branch is protected ---

IS_PROTECTED=false
for pb in $PROTECTED_BRANCHES; do
  if [ "$BRANCH" = "$pb" ]; then
    IS_PROTECTED=true
    break
  fi
done

if [ "$IS_PROTECTED" = "false" ]; then
  exit 0
fi

# --- ASK: on protected branch, editing confirmable paths (memory/napkin) ---
# Non-project files: auto-memory (outside the repo) and curated napkin (inside .context/).
# Emit permissionDecision=ask so Claude Code prompts the user per edit.

if [ -n "$FILE_PATH" ]; then
  case "$FILE_PATH" in
    */.claude/projects/*/memory/*|*/.context/napkin.md)
      ask_reason=$(render_msg "$MSG_ASK_HEADER" "file_path=${FILE_PATH}" "branch=${BRANCH}")
      REASON_ESCAPED=$(escape_for_json "$ask_reason")
      printf '{\n  "hookSpecificOutput": {\n    "hookEventName": "PreToolUse",\n    "permissionDecision": "ask",\n    "permissionDecisionReason": "%s"\n  }\n}\n' "$REASON_ESCAPED"
      exit 0
      ;;
  esac
fi

# --- BLOCK: on protected branch, editing project source code ---

blocked_header=$(render_msg "$MSG_BLOCKED_HEADER" "branch=${BRANCH}")
blocked_file=$(render_msg "$MSG_BLOCKED_FILE" "file_path=${FILE_PATH}")

REASON="${blocked_header}

${MSG_BLOCKED_ACTION}

${blocked_file}

${MSG_BLOCKED_NOTE}"

REASON_ESCAPED=$(escape_for_json "$REASON")

printf '{\n  "hookSpecificOutput": {\n    "hookEventName": "PreToolUse",\n    "permissionDecision": "deny",\n    "permissionDecisionReason": "%s"\n  }\n}\n' "$REASON_ESCAPED"

exit 0
