{
  "mcpServers": {
    "dotcontext": {
      "command": "npx",
      "args": [
        "-y",
        "@dotcontext/cli@latest",
        "--lang",
        "pt-BR",
        "mcp"
      ],
      "env": {}
    },
    "mempalace": {
      "command": "python",
      "args": [
        "-m",
        "mempalace.mcp_server"
      ]
    },
    "docs-mcp-server": {
      "type": "sse",
      "url": "http://localhost:6280/sse"
    }
  }
}
